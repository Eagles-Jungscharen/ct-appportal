# ============================================
# Frontend Environment Variables (VITE_*)
# ============================================

# Churchtool OIDC Provider
VITE_OIDC_AUTHORITY=https://your-churchtool-idp.example.com
VITE_OIDC_CLIENT_ID=your-client-id
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Azure Functions Backend
VITE_API_BASE_URL=http://localhost:7071

# Branding (optional)
VITE_ORGANIZATION_NAME=Eagles Jungscharen
VITE_APP_PORTAL_TITLE=App-Portal
VITE_APP_ICON_URL=https://example.com/path/to/your/icon.png

# ============================================
# Backend Environment Variables
# ============================================

# Azure Storage (Azurite for local development)
AZURE_WEB_JOBS_STORAGE=UseDevelopmentStorage=true

# Azure Functions Runtime
FUNCTIONS_WORKER_RUNTIME=dotnet-isolated

# Application Insights (optional, leave empty for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# OIDC Authentication
OIDC_AUTHORITY_URL=https://your-churchtool-idp.example.com/api/oidc

# Churchtool IDP Integration
CHURCHTOOL_IDP_BASE_URL=https://your-churchtool-idp.example.com
CHURCHTOOL_IDP_FUNCTION_KEY=your-function-key-here

# Churchtool API
CHURCHTOOL_URL=https://your-org.church.tools
CHURCHTOOL_ADMIN_GROUP_ID=6

# Churchtool IDP Storage (for user tokens)
CHURCHTOOL_IDP_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# CORS Configuration (for local development)
CORS_ORIGINS=http://localhost:5173
CORS_CREDENTIALS=true
